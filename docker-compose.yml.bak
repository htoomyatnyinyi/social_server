services:
  # ────────────────────────────────────────────────
  # PostgreSQL for SOCIAL APP
  social_db:
    image: postgres:16-alpine
    restart: always
    environment:
      POSTGRES_USER: oasis
      POSTGRES_PASSWORD: oasis_password_change_me_please
      POSTGRES_DB: social_db # Matches DATABASE_URL
    ports:
      - "5432:5432"
    volumes:
      - social_pgdata:/var/lib/postgresql/data
    healthcheck:
      # FIX: Added -d social_db so pg_isready pings the right database
      test: ["CMD", "pg_isready", "-U", "oasis", "-d", "social_db"]
      interval: 10s
      timeout: 5s
      retries: 5

  redis:
    image: redis:alpine
    restart: always
    ports:
      - "6379:6379"

  api:
    build: .
    restart: always
    ports:
      - "8080:8080"
    env_file:
      - .env
    # Note: DATABASE_URL in .env will be used. Ensure it matches social_db service name.
    depends_on:
      social_db:
        condition: service_healthy
      redis:
        condition: service_started
      zipline:
        condition: service_started

  # ────────────────────────────────────────────────
  # Zipline Database
  zipline_db:
    image: postgres:16-alpine
    restart: always
    environment:
      POSTGRES_USER: zipline
      POSTGRES_PASSWORD: zipline_strong_password_change_me
      POSTGRES_DB: zipline
    volumes:
      - zipline_pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD", "pg_isready", "-U", "zipline", "-d", "zipline"]
      interval: 10s
      timeout: 5s
      retries: 5

  minio:
    image: minio/minio:latest
    restart: always
    ports:
      - "9000:9000"
      - "9001:9001"
    environment:
      MINIO_ROOT_USER: minioadmin_change_me
      MINIO_ROOT_PASSWORD: very_long_minio_password_change_me_1234567890
    command: server /data --console-address ":9001"
    volumes:
      - minio_data:/data
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/minio/health/live"]
      interval: 30s
      timeout: 20s
      retries: 3

  createbucket:
    image: minio/mc:latest
    depends_on:
      minio:
        condition: service_healthy
    entrypoint: >
      /bin/sh -c "
      mc alias set local http://minio:9000 $${MINIO_ROOT_USER} $${MINIO_ROOT_PASSWORD} &&
      mc mb local/ziplinebucket --ignore-existing &&
      mc anonymous set download local/ziplinebucket &&
      echo 'Bucket ready'
      "
    environment:
      MINIO_ROOT_USER: minioadmin_change_me
      MINIO_ROOT_PASSWORD: very_long_minio_password_change_me_1234567890
    restart: "no"

  zipline:
    image: ghcr.io/diced/zipline:latest
    restart: unless-stopped
    ports:
      - "3000:3000"
    environment:
      CORE_SECRET: change_this_to_a_very_long_random_string_64_chars_plus
      CORE_RETURN_ORIGINAL: "1"
      DATABASE_URL: postgresql://zipline:zipline_strong_password_change_me@zipline_db:5432/zipline
      REDIS_URL: redis://redis:6379 # add on by me if not effective can be remove
      DATASOURCE_TYPE: s3
      DATASOURCE_S3_ENDPOINT: http://minio:9000
      DATASOURCE_S3_ACCESS_KEY_ID: minioadmin_change_me
      DATASOURCE_S3_SECRET_ACCESS_KEY: very_long_minio_password_change_me_1234567890
      DATASOURCE_S3_BUCKET: ziplinebucket
      DATASOURCE_S3_FORCE_PATH_STYLE: "true"
      DATASOURCE_S3_REGION: us-east-1
      DATASOURCE_S3_USE_SSL: "false"
    volumes:
      - ./zipline_data:/app/data
    depends_on:
      zipline_db:
        condition: service_healthy
      minio:
        condition: service_healthy
      createbucket:
        condition: service_completed_successfully

volumes:
  social_pgdata:
  zipline_pgdata:
  minio_data:

# # BEFORE UPGRADE FROM MYSQL TO POSTGRESQL
# # services:
# #   # ────────────────────────────────────────────────
# #   # Your social media backend database (MySQL)
# #   # If you later decide to switch the social app to PostgreSQL too, we can unify databases
# #   db:
# #     image: mysql:8.0 # Pin a specific version for stability (avoid 'latest' surprises)
# #     restart: always
# #     environment:
# #       MYSQL_ROOT_PASSWORD: root_password_change_me_please
# #       MYSQL_DATABASE: social_db
# #       MYSQL_USER: oasis
# #       MYSQL_PASSWORD: oasis_password_change_me_please
# #     ports:
# #       - "3306:3306" # Expose only if you need external tools (e.g. MySQL Workbench); remove in production
# #     volumes:
# #       - mysql_data:/var/lib/mysql # Persistent data storage
# #     healthcheck: # Ensures the DB is ready before dependent services start
# #       test:
# #         [
# #           "CMD-SHELL",
# #           "mysqladmin ping -h localhost -u oasis -p$${MYSQL_PASSWORD}",
# #         ]
# #       interval: 10s
# #       timeout: 5s
# #       retries: 5

# #   # Redis for caching, sessions, queues, etc. in your social app
# #   redis:
# #     image: redis:alpine # Lightweight, official Redis image
# #     restart: always
# #     ports:
# #       - "6379:6379" # Optional: expose only for local debugging
# #     # volumes:                       # Uncomment if you want persistent Redis data
# #     #   - redis_data:/data

# #   # Your custom API/backend service (built from current directory)
# #   api:
# #     build: . # Builds from your Dockerfile in the current folder
# #     restart: always
# #     ports:
# #       - "8080:8080" # Your API listens here
# #     env_file:
# #       - .env # Load additional secrets/vars from .env file
# #     environment:
# #       DATABASE_URL: "mysql://oasis:oasis_password_change_me_please@db:3306/social_db"
# #       REDIS_URL: "redis://redis:6379"
# #       PORT: 8080
# #     depends_on: # Wait for healthy dependencies
# #       db:
# #         condition: service_healthy
# #       redis:
# #         condition: service_started

# #   # ────────────────────────────────────────────────
# #   # Zipline PostgreSQL database (official recommendation for Zipline)
# #   zipline_db:
# #     image: postgres:16-alpine # Lightweight, stable Postgres version
# #     restart: always
# #     environment:
# #       POSTGRES_USER: zipline
# #       POSTGRES_PASSWORD: zipline_strong_password_change_me
# #       POSTGRES_DB: zipline
# #     volumes:
# #       - zipline_pgdata:/var/lib/postgresql/data # Persistent DB storage
# #     healthcheck: # Simple readiness check
# #       test: ["CMD", "pg_isready", "-U", "zipline"]
# #       interval: 10s
# #       timeout: 5s
# #       retries: 5

# #   # MinIO: Self-hosted S3-compatible object storage for Zipline files/images
# #   # This replaces local disk storage → better for many/small files in social apps
# #   minio:
# #     image: minio/minio:latest
# #     restart: always
# #     ports:
# #       - "9000:9000" # S3 API endpoint (internal use by Zipline)
# #       - "9001:9001" # MinIO web console → http://your-ip:9001 (great for browsing buckets)
# #     environment:
# #       MINIO_ROOT_USER: minioadmin_change_me
# #       MINIO_ROOT_PASSWORD: very_long_strong_minio_password_change_me_1234567890
# #     command: server /data --console-address ":9001" # Starts server + web UI
# #     volumes:
# #       - minio_data:/data # Where all uploaded files live
# #     healthcheck: # Official MinIO health endpoint
# #       test: ["CMD", "curl", "-f", "http://localhost:9000/minio/health/live"]
# #       interval: 30s
# #       timeout: 20s
# #       retries: 3

# #   # One-time job: Creates the bucket and sets it to public downloads (for image embeds/sharing)
# #   createbucket:
# #     image: minio/mc:latest # Official MinIO Client (mc)
# #     depends_on:
# #       minio:
# #         condition: service_healthy
# #     entrypoint: >
# #       /bin/sh -c "
# #       mc alias set local http://minio:9000 $${MINIO_ROOT_USER} $${MINIO_ROOT_PASSWORD} &&
# #       mc mb local/ziplinebucket --ignore-existing &&
# #       mc anonymous set download local/ziplinebucket &&
# #       echo 'Zipline bucket created and set to public'
# #       "
# #     environment:
# #       MINIO_ROOT_USER: minioadmin_change_me
# #       MINIO_ROOT_PASSWORD: very_long_strong_minio_password_change_me_1234567890
# #     restart: "no" # Runs once and exits successfully

# #   # Zipline: The file upload/share server (uses MinIO for storage)
# #   zipline:
# #     image: ghcr.io/diced/zipline:latest
# #     restart: unless-stopped
# #     ports:
# #       - "3000:3000" # Dashboard at http://your-ip:3000
# #     environment:
# #       # Core Zipline settings
# #       CORE_SECRET: change_this_to_a_very_long_random_string_64_chars_plus # Must be secure & random!
# #       CORE_RETURN_ORIGINAL: "1" # Optional: return original file URLs in some cases

# #       # Database connection (Postgres)
# #       DATABASE_URL: postgresql://zipline:zipline_strong_password_change_me@zipline_db:5432/zipline

# #       # S3 / MinIO configuration → this enables MinIO-only storage
# #       DATASOURCE_TYPE: s3
# #       DATASOURCE_S3_ENDPOINT: http://minio:9000 # Internal Docker network address
# #       DATASOURCE_S3_ACCESS_KEY_ID: minioadmin_change_me
# #       DATASOURCE_S3_SECRET_ACCESS_KEY: very_long_strong_minio_password_change_me_1234567890
# #       DATASOURCE_S3_BUCKET: ziplinebucket # Must match createbucket
# #       DATASOURCE_S3_FORCE_PATH_STYLE: "true" # Required for MinIO (not AWS)
# #       DATASOURCE_S3_REGION: us-east-1 # Dummy value (MinIO ignores it)
# #       DATASOURCE_S3_USE_SSL: "false" # No HTTPS inside Docker network
# #     volumes:
# #       - ./zipline_data:/app/data # Zipline config, logs, thumbnails, etc. (NOT user uploads!)
# #     depends_on: # Ensures everything is ready
# #       zipline_db:
# #         condition: service_healthy
# #       minio:
# #         condition: service_healthy
# #       createbucket:
# #         condition: service_completed_successfully

